PALETTE_NAMES = [
    " 0 black    ", " 1 red      ", " 2 green    ", " 3 yellow   ",
    " 4 blue     ", " 5 magenta  ", " 6 cyan     ", " 7 white    ",
    " 8 br.black ", " 9 br.red   ", "10 br.green ", "11 br.yellow",
    "12 br.blue  ", "13 br.mag   ", "14 br.cyan  ", "15 br.white ",
]


def section(title, width=95):
    print(f"\n{BOLD}{'=' * width}")
    print(f"  {title}")
    print(f"{'=' * width}{RESET}\n")


def render_palettes(names):
    section("COLOR PALETTES")
    # exclude themes with incomplete palettes
    names = [n for n in names if all(themes[n]["palette"])]

    header = "              "
    for n in names:
        header += f"  {BOLD}{n:<16}{RESET}"
    print(header)
    print()

    for i in range(16):
        row = f"  {PALETTE_NAMES[i]}  "
        for n in names:
            c = themes[n]["palette"][i]
            if n == "Custom":
                row += f"{fg(c)}{BLOCK}{RESET} {c} {custom_sources['palette'][i]:<5s}"
            else:
                row += f"{fg(c)}{BLOCK}{RESET} {c}      "
        print(row)
        if i == 7:
            print()

    print()

    for key in ["bg", "fg", "cursor", "sel_bg"]:
        labels = {"bg": "bg         ", "fg": "fg         ", "cursor": "cursor     ", "sel_bg": "selection  "}
        row = f"  {labels[key]}   "
        for n in names:
            td = themes[n]
            c = td[key]
            if key == "bg":
                row += f"{bg(c)}  {RESET} {c}      "
            elif key == "sel_bg":
                src = f" {custom_sources[key]:<5s}" if n == "Custom" else "       "
                row += f"{bg(td['sel_bg'])}{fg(td['sel_fg'])}sel{RESET} {c}{src}"
            else:
                src = f" {custom_sources[key]:<5s}" if n == "Custom" else "      "
                row += f"{fg(c)}{BLOCK}{RESET} {c}{src}"
        print(row)


def render_prompt(name, t):
    p = t["palette"]
    if not p[BR_RED] or not p[BR_BLUE] or not p[BR_MAGENTA]:
        return
    conn = p[WHITE] or "#cccccc"
    print(f"{BOLD}{name}{RESET}")
    print(
        f"  {BOLD}{fg(p[BR_RED])}tk"
        f"{RESET}{fg(conn)} at "
        f"{BOLD}{fg(p[BR_GREEN])}suzuki"
        f"{RESET}{fg(conn)} in "
        f"{BOLD}{fg(p[BR_BLUE])}~/code/project"
        f"{RESET}{fg(conn)} on "
        f"{BOLD}{fg(p[BR_YELLOW])}main +3"
        f"{RESET}{fg(conn)} via "
        f"{BOLD}{fg(p[BR_MAGENTA])}caspian"
        f"{RESET}  {fg(conn)}1.2s {fg(p[GREEN])}\u2713{RESET}"
    )
    print(f"  {BOLD}{fg(p[BR_WHITE])}$ {RESET}ls -la")
    w = conn
    print(f"  {fg(w)}total 42{RESET}")
    print(f"  {fg(p[BLUE])}drwxr-xr-x{RESET}  {fg(w)}tk tk  4096 Mar  3{RESET}  {BOLD}{fg(p[BLUE])}src/{RESET}")
    print(f"  {fg(p[BLUE])}drwxr-xr-x{RESET}  {fg(w)}tk tk  4096 Mar  3{RESET}  {BOLD}{fg(p[BLUE])}tests/{RESET}")
    print(f"  {fg(w)}-rw-r--r--{RESET}  {fg(w)}tk tk  1234 Mar  3{RESET}  {fg(w)}README.md{RESET}")
    print(f"  {fg(w)}-rw-r--r--{RESET}  {fg(w)}tk tk   567 Mar  3{RESET}  {fg(p[YELLOW])}Makefile{RESET}")
    print(f"  {BOLD}{fg(p[GREEN])}-rwxr-xr-x{RESET}  {fg(w)}tk tk  8901 Mar  3{RESET}  {BOLD}{fg(p[GREEN])}build.sh{RESET}")
    print(f"  {BOLD}{fg(p[GREEN])}-rwxr-xr-x{RESET}  {fg(w)}tk tk  2345 Mar  3{RESET}  {BOLD}{fg(p[GREEN])}run{RESET}")
    print()


def render_statusline(name, t):
    p = t["palette"]
    gray = p[BR_BLACK] or "#767676"
    purple = p[BR_MAGENTA]
    if not purple:
        purple = "#0c0c0c"
    gsep = f"{fg(gray)}{NBSP}|{NBSP}{RESET}"
    line = (
        f"{RESET}{fg(purple)}Opus 4.6{gsep}"
        f"{fg(p[BR_BLUE])} main{gsep}"
        f"{fg(p[BR_GREEN])}42%{gsep}"
        f"{fg(p[BR_YELLOW])}1.2M{gsep}"
        f"{fg(p[BR_RED])}$3.50{RESET}"
    )
    print(f"{BOLD}{name}{RESET}")
    print(f"  {line}")
    print()


def render_prompts(names):
    section("BASH PROMPT RENDERINGS")
    for n in names:
        render_prompt(n, themes[n])


def render_statuslines(names):
    section("STATUSLINE RENDERINGS (using bright palette colors)")

    for n in names:
        p = themes[n]["palette"]
        if not p[BR_BLUE]:
            continue
        render_statusline(n, themes[n])


def render(names):
    render_palettes(names)
    render_prompts(names)
    render_statuslines(names)


def main():
    args = sys.argv[1:]
    if args:
        for name in args:
            if name not in themes:
                print(f"Unknown theme: {name}")
                print(f"Available: {', '.join(n for n in themes if n != 'Custom')}")
                sys.exit(1)
        names = [n for n in args if n != "Custom"] + ["Custom"]
    else:
        names = [n for n in themes if n != "Custom"] + ["Custom"]
    render(names)


main()
