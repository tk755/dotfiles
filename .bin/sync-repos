#!/usr/bin/env bash

set -euo pipefail

# default flags
DRY_RUN=false

print_help() {
    cat <<EOF
Usage: sync-repos [DIR] [OPTIONS]

Options:
    --dry-run   List discovered repositories without syncing
    --help      Show this help message

Description:
    Syncs all git repositories found recursively under DIR.
      - If DIR is omitted, the current working directory is used.
      - Makes no destructive changes, either locally or remotely.

    For each repository:
      - Runs 'git fetch --prune --tags' to update remotes and tags
      - Runs 'git pull --ff-only' to update the current branch
EOF
}

parse_args() {
    POSITIONAL=()
    for arg in "$@"; do
        case "$arg" in
            --dry-run)  DRY_RUN=true                          ;;
            --help)     print_help ; exit 0                   ;;
            -*)         echo "Invalid option: $arg" && exit 1 ;;
            *)          POSITIONAL+=("$arg")                  ;;
        esac
    done

    if [ "${#POSITIONAL[@]}" -gt 1 ]; then
        echo "Expected at most one positional argument" >&2
        exit 1
    fi

    REPOS_DIR=$(realpath "${POSITIONAL[0]:-$PWD}")

    if [ ! -d "$REPOS_DIR" ]; then
        echo "Not a directory: $REPOS_DIR" >&2
        exit 1
    fi
}

print_status() {
    local repo_name="$1"
    local message="$2"
    local emoji="$3"

    local color="" style="" reset="\e[0m"
    case "$emoji" in
        "✓" )  color="\e[32m" ;;  # green
        "×" )  color="\e[31m" ;;  # red
        "↓" )  color="\e[36m" ;;  # cyan
        " " )  style="\e[2m"  ;;  # dim
        * )    ;;
    esac

    printf " %b%s%b %b%-${REPO_COL_WIDTH}s %s%b\n" \
        "$color" "$emoji" "$reset" "$style" "$repo_name" "$message" "$reset"
}

pull_repo() {
    local repo_path="$1"
    local repo_name="${repo_path#"$REPOS_DIR"/}"
    cd "$repo_path"

    # ensure we are on a branch with an upstream
    local branch
    if ! branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null); then
        print_status "$repo_name" "No branch" "×"
        return
    fi

    # ensure we have an upstream branch
    if ! git rev-parse --abbrev-ref "@{u}" > /dev/null 2>&1; then
        print_status "$repo_name" "No upstream" "×"
        return
    fi

    # fetch remote updates and prune deleted branches
    if ! git fetch --prune --quiet 2>/dev/null; then
        print_status "$repo_name" "Remote not found" "×"
        return
    fi

    # fetch tags separately to detect conflicts
    if ! git fetch --tags --quiet 2>/dev/null; then
        print_status "$repo_name" "Tag conflict" "×"
        return
    fi

    local LOCAL REMOTE BASE
    LOCAL=$(git rev-parse @)
    REMOTE=$(git rev-parse "@{u}")
    BASE=$(git merge-base @ "@{u}" 2>/dev/null || true)

    if [ -z "$BASE" ]; then
        print_status "$repo_name" "Unrelated history" "×"
    elif [ "$LOCAL" = "$REMOTE" ]; then
        print_status "$repo_name" "Up-to-date" "✓"
    elif [ "$LOCAL" = "$BASE" ]; then
        if git pull --ff-only --quiet &>/dev/null; then
            print_status "$repo_name" "Pulled" "↓"
        else
            print_status "$repo_name" "Local changes" "×"
        fi
    else
        print_status "$repo_name" "Diverged" "×"
    fi
}

main() {
    parse_args "$@"

    # discover repos recursively
    mapfile -t repo_paths < <(find "$REPOS_DIR" -name ".git" -type d -prune | sed 's|/\.git$||' | sort)

    if [ ${#repo_paths[@]} -eq 0 ]; then
        echo "No repositories found in $REPOS_DIR"
        exit 0
    fi

    # dry run: list repos and exit
    if [ "$DRY_RUN" = true ]; then
        for repo_path in "${repo_paths[@]}"; do
            echo "${repo_path#"$REPOS_DIR"/}"
        done
        exit 0
    fi

    # calculate column width from relative paths
    REPO_COL_WIDTH=0
    for repo_path in "${repo_paths[@]}"; do
        repo_name="${repo_path#"$REPOS_DIR"/}"
        len=${#repo_name}
        if [ "$len" -gt "$REPO_COL_WIDTH" ]; then
            REPO_COL_WIDTH=$len
        fi
    done
    REPO_COL_WIDTH=$((REPO_COL_WIDTH + 2))

    echo -e "\e[1mSyncing repos in $REPOS_DIR\e[0m"

    # export for subshells
    export REPOS_DIR REPO_COL_WIDTH
    export -f pull_repo print_status

    # sync each repo in parallel using background jobs
    for repo_path in "${repo_paths[@]}"; do
        pull_repo "$repo_path" &
    done

    # wait for all background jobs to finish
    wait

    echo -e "\e[1mDone\e[0m"
}

main "$@"
