#!/usr/bin/env bash
set -euo pipefail

# suzuki install
#
# Hardware
#   Framework 13 (AMD Ryzen 5 7640U)
#   64GB DDR5, 2TB WD Black SN850X (4K native), MT7921 Wi-Fi
#   13.5" 2880x1920 120Hz (BOE0CB4), Radeon 760M (RDNA 3)
#
# OS:         Arch Linux
# Filesystem: btrfs, subvolumes: @ @home @snapshots @var_log @var_cache
# Encryption: LUKS2, sd-encrypt (not busybox, supports LUKS2 + TPM2)
# Bootloader: systemd-boot
# Swap:       zram ram/2 (no swap partition)
# Desktop:    sway (Wayland)
# Network:    NetworkManager + iwd backend (MT7921 stability)
# Power:      power-profiles-daemon (not tlp, AMD/Framework conflict)
# Snapshots:  snapper + snap-pac (pacman hooks, no timeline)
#
# Boot the Arch ISO. Then run:
#   iwctl station wlan0 connect "YourNetworkName"
#   pacman -Sy git
#   git clone https://github.com/tk755/dotfiles
#   dotfiles/.hosts/suzuki/install

DRIVE="/dev/nvme0n1"
EFI_PART="${DRIVE}p1"
ROOT_PART="${DRIVE}p2"
CRYPT_NAME="cryptroot"
CRYPT_DEV="/dev/mapper/${CRYPT_NAME}"
MOUNT="/mnt"
BTRFS_OPTS="compress=zstd,noatime,discard=async"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

msg() {
    printf '\033[1;35m%s\033[0m\n' "$1"
}

warn() {
    printf '\033[1;33m%s\033[0m\n' "$1"
}

aur_install() {
    # https://wiki.archlinux.org/title/Sudo#Configuration
    # paru calls sudo pacman internally, no TTY in chroot for password prompt
    # grant scoped NOPASSWD for pacman only, remove after install
    local sudoers="${MOUNT}/etc/sudoers.d/99-paru"
    echo 'tk ALL=(ALL) NOPASSWD: /usr/bin/pacman' > "$sudoers"
    chmod 440 "$sudoers"
    arch-chroot "$MOUNT" su - tk -c "paru -S --noconfirm --needed $*"
    rm -f "$sudoers"
}

precheck() {
    if [[ ! -d /run/archiso ]]; then
        echo "error: must run from the Arch ISO" >&2
        exit 1
    fi
    if (( EUID != 0 )); then
        echo "error: must run as root" >&2
        exit 1
    fi
    # https://wiki.archlinux.org/title/Installation_guide#Verify_the_boot_mode
    if [[ ! -f /sys/firmware/efi/fw_platform_size ]]; then
        echo "error: not booted in UEFI mode" >&2
        exit 1
    fi
    if [[ "$(< /sys/firmware/efi/fw_platform_size)" != "64" ]]; then
        echo "error: UEFI is not 64-bit" >&2
        exit 1
    fi
    if [[ ! -b "$DRIVE" ]]; then
        echo "error: drive ${DRIVE} not found" >&2
        exit 1
    fi
    if ! ping -c 1 -W 3 ping.archlinux.org &>/dev/null; then
        echo "error: no internet, connect with iwctl first" >&2
        exit 1
    fi
    if [[ ! -f "${SCRIPT_DIR}/../../.bin/bootstrap" ]]; then
        echo "error: bootstrap script not found at ${SCRIPT_DIR}/../../.bin/bootstrap" >&2
        exit 1
    fi
    # clean up from a previous failed run
    umount -R "$MOUNT" 2>/dev/null || true
    if [[ -b "$CRYPT_DEV" ]]; then
        cryptsetup close "$CRYPT_NAME" || true
    fi
}

get_password() {
    echo "Set a password for LUKS encryption, root, and tk"
    while true; do
        read -rsp "Password: " PASSWORD
        echo
        read -rsp "Confirm: " confirm
        echo
        if [[ "$PASSWORD" == "$confirm" ]]; then
            break
        fi
        echo "Passwords do not match, try again"
    done
}

update_mirrors() {
    # https://wiki.archlinux.org/title/Reflector
    # 10 freshest US mirrors, sorted by download speed
    reflector --country US --protocol https --age 24 --latest 10 --sort rate \
        --threads 10 --save /etc/pacman.d/mirrorlist
}

format_nvme() {
    # https://wiki.archlinux.org/title/NVMe#Sector_size
    if nvme id-ns "$DRIVE" -H | grep 'in use' | grep -q '4096'; then
        echo "NVMe already using 4K sectors, skipping"
        return
    fi
    # LBA format 1 = 4096-byte sectors (matches physical sector size)
    nvme format "$DRIVE" --lbaf=1
}

partition() {
    # https://wiki.archlinux.org/title/Installation_guide#Partition_the_disks
    # wipe all filesystem signatures from the drive
    wipefs -af "$DRIVE"
    # 1G EFI + rest as linux root
    sfdisk "$DRIVE" <<EOF
label: gpt
size=1G, type=uefi
type=linux
EOF
}

encrypt() {
    # https://wiki.archlinux.org/title/Dm-crypt/Device_encryption#Encryption_options_for_LUKS_mode
    # defaults: LUKS2, aes-xts-plain64, argon2id (no GRUB PBKDF2 limitation with systemd-boot)
    printf '%s' "$PASSWORD" | cryptsetup luksFormat -q --key-file=- "$ROOT_PART"

    # https://wiki.archlinux.org/title/Dm-crypt/Specialties#Discard/TRIM_support_for_solid_state_drives_(SSD)
    # --allow-discards: let TRIM pass through the crypt layer
    # --persistent: store the flag in the LUKS header permanently
    printf '%s' "$PASSWORD" | cryptsetup open --allow-discards --persistent --key-file=- "$ROOT_PART" "$CRYPT_NAME"
}

create_filesystems() {
    # https://wiki.archlinux.org/title/EFI_system_partition#Format_the_partition
    # https://wiki.archlinux.org/title/Btrfs#Creating_a_file_system
    mkfs.fat -F 32 "$EFI_PART"
    mkfs.btrfs -f "$CRYPT_DEV"

    # temporarily mount the raw volume to create subvolumes
    mount "$CRYPT_DEV" "$MOUNT"
    local subvols=(@ @home @snapshots @var_log @var_cache)
    for sv in "${subvols[@]}"; do
        btrfs subvolume create "${MOUNT}/${sv}"
    done
    umount "$MOUNT"
}

mount_filesystems() {
    # https://wiki.archlinux.org/title/Btrfs#Mounting_subvolumes
    # root subvol first, then nested mountpoints
    mount -o "${BTRFS_OPTS},subvol=@" "$CRYPT_DEV" "$MOUNT"
    mkdir -p "${MOUNT}"/{home,.snapshots,var/log,var/cache,boot}
    mount -o "${BTRFS_OPTS},subvol=@home" "$CRYPT_DEV" "${MOUNT}/home"
    mount -o "${BTRFS_OPTS},subvol=@snapshots" "$CRYPT_DEV" "${MOUNT}/.snapshots"
    mount -o "${BTRFS_OPTS},subvol=@var_log" "$CRYPT_DEV" "${MOUNT}/var/log"
    mount -o "${BTRFS_OPTS},subvol=@var_cache" "$CRYPT_DEV" "${MOUNT}/var/cache"
    mount "$EFI_PART" "${MOUNT}/boot"
}

install_base() {
    # https://wiki.archlinux.org/title/Installation_guide#Install_essential_packages
    # cryptsetup and btrfs-progs are not in base, without them the system won't boot
    # -K initializes an empty pacman keyring in the new root
    pacstrap -K "$MOUNT" \
        base base-devel linux linux-firmware amd-ucode \
        cryptsetup btrfs-progs \
        networkmanager iwd \
        nano git man-db man-pages
}

generate_fstab() {
    # https://wiki.archlinux.org/title/Installation_guide#Fstab
    # -U uses UUIDs (stable across device reordering)
    genfstab -U "$MOUNT" >> "${MOUNT}/etc/fstab"

    # https://wiki.archlinux.org/title/Btrfs#Mounting_subvolumes
    # without stripping subvolid, a snapper rollback leaves a stale id that fails the mount
    sed -i -e 's/,subvolid=[0-9]*//g' -e 's/subvolid=[0-9]*,//g' "${MOUNT}/etc/fstab"
}

configure_system() {
    # https://wiki.archlinux.org/title/Installation_guide#Time
    # timedatectl/hostnamectl/localectl require dbus, unavailable in chroot
    arch-chroot "$MOUNT" ln -sf /usr/share/zoneinfo/America/New_York /etc/localtime
    # sync hardware clock from system time
    arch-chroot "$MOUNT" hwclock --systohc

    # https://wiki.archlinux.org/title/Installation_guide#Localization
    cat > "${MOUNT}/etc/locale.gen" <<'EOF'
en_US.UTF-8 UTF-8
EOF
    cat > "${MOUNT}/etc/locale.conf" <<'EOF'
LANG=en_US.UTF-8
EOF
    cat > "${MOUNT}/etc/vconsole.conf" <<'EOF'
KEYMAP=us
EOF
    arch-chroot "$MOUNT" locale-gen

    echo "suzuki" > "${MOUNT}/etc/hostname"

    # https://wiki.archlinux.org/title/Installation_guide#Root_password
    # https://wiki.archlinux.org/title/Users_and_groups#User_management
    arch-chroot "$MOUNT" useradd -m -G wheel -s /bin/bash tk
    # set root and tk passwords in bulk (user:pass format via stdin)
    printf 'root:%s\ntk:%s\n' "$PASSWORD" "$PASSWORD" | arch-chroot "$MOUNT" chpasswd

    # https://wiki.archlinux.org/title/Sudo#Configuration
    # sed, not visudo, known-good syntax, single uncomment operation
    arch-chroot "$MOUNT" sed -i \
        's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

    # https://wiki.archlinux.org/title/Framework_Laptop_13_(AMD_Ryzen_7040_Series)#Display
    # BOE0CB4 panel color profile for Framework 13
    mkdir -p "${MOUNT}/usr/share/color/icc"
    cp "${SCRIPT_DIR}/BOE0CB4_01.icm" \
        "${MOUNT}/usr/share/color/icc/BOE0CB4_01.icm"
}

configure_boot() {
    # https://wiki.archlinux.org/title/Dm-crypt/Encrypting_an_entire_system#Configuring_mkinitcpio
    # systemd-based hooks for LUKS2 + TPM2 support (sd-encrypt)
    cat > "${MOUNT}/etc/mkinitcpio.conf" <<'EOF'
MODULES=()
BINARIES=()
FILES=()
HOOKS=(base systemd autodetect microcode modconf kms keyboard sd-vconsole block sd-encrypt filesystems fsck)
EOF
    arch-chroot "$MOUNT" mkinitcpio -P

    # https://wiki.archlinux.org/title/Systemd-boot#Installation
    # install systemd-boot EFI binaries to the ESP
    arch-chroot "$MOUNT" bootctl install

    # https://wiki.archlinux.org/title/Systemd-boot#Loader_configuration
    cat > "${MOUNT}/boot/loader/loader.conf" <<'EOF'
default arch.conf
timeout 0
editor no
EOF

    # https://wiki.archlinux.org/title/Dm-crypt/Encrypting_an_entire_system#Configuring_the_boot_loader_2
    # https://wiki.archlinux.org/title/Zswap#Toggling_zswap
    # https://wiki.archlinux.org/title/Framework_Laptop_13_(AMD_Ryzen_7040_Series)#Video_freezes
    #
    # kernel parameters:
    #   rd.luks.name        sd-encrypt syntax (not cryptdevice= which is for the busybox encrypt hook)
    #   rd.luks.options     tpm2 auto-unlock, falls back to password prompt if not enrolled
    #   zswap.enabled=0     disable zswap so zram works (zswap intercepts pages before they reach zram)
    #   amdgpu.dcdebugmask  display freeze workaround (DMUB flip_done timed out)
    local uuid
    uuid="$(blkid -s UUID -o value "$ROOT_PART")"
    mkdir -p "${MOUNT}/boot/loader/entries"
    cat > "${MOUNT}/boot/loader/entries/arch.conf" <<EOF
title   Arch Linux
linux   /vmlinuz-linux
initrd  /amd-ucode.img
initrd  /initramfs-linux.img
options rd.luks.name=${uuid}=cryptroot root=/dev/mapper/cryptroot rootflags=subvol=@ rw rd.luks.options=tpm2-device=auto zswap.enabled=0 amdgpu.dcdebugmask=0x10
EOF
}

configure_network() {
    # https://wiki.archlinux.org/title/NetworkManager#Using_iwd_as_the_Wi-Fi_backend
    mkdir -p "${MOUNT}/etc/NetworkManager/conf.d"
    cat > "${MOUNT}/etc/NetworkManager/conf.d/wifi-backend.conf" <<'EOF'
[device]
wifi.backend=iwd
EOF

    # https://wiki.archlinux.org/title/Framework_Laptop_13_(AMD_Ryzen_7040_Series)#Wi-Fi
    # https://wiki.archlinux.org/title/Network_configuration/Wireless#Respecting_the_regulatory_domain
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm wireless-regdb
    mkdir -p "${MOUNT}/etc/conf.d"
    cat > "${MOUNT}/etc/conf.d/wireless-regdom" <<'EOF'
WIRELESS_REGDOM="US"
EOF

    # https://wiki.archlinux.org/title/Framework_Laptop_13_(AMD_Ryzen_7040_Series)#Power_management
    # rfkill wifi/bt before suspend to prevent MT7921 firmware hangs
    mkdir -p "${MOUNT}/etc/systemd/system"
    cp "${SCRIPT_DIR}/systemd/rfkill-before-sleep.service" \
        "${MOUNT}/etc/systemd/system/rfkill-before-sleep.service"

    arch-chroot "$MOUNT" systemctl enable \
        NetworkManager \
        systemd-timesyncd.service \
        rfkill-before-sleep.service
}

build_paru() {
    # https://wiki.archlinux.org/title/AUR_helpers
    # https://wiki.archlinux.org/title/Arch_User_Repository#Installing_and_upgrading_packages
    # makepkg refuses root, build as tk, install as root
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm rust

    arch-chroot "$MOUNT" su - tk -c 'git clone https://aur.archlinux.org/paru.git /home/tk/paru'
    arch-chroot "$MOUNT" su - tk -c 'cd /home/tk/paru && makepkg --noconfirm'
    arch-chroot "$MOUNT" bash -c 'pacman -U --noconfirm /home/tk/paru/*.pkg.tar.zst'

    rm -rf "${MOUNT}/home/tk/paru"
    arch-chroot "$MOUNT" pacman -Rns --noconfirm rust
}

install_desktop() {
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm \
        pacman-contrib \
        polkit brightnessctl \
        mesa vulkan-radeon vulkan-icd-loader \
        sway waybar xdg-desktop-portal-gtk xdg-desktop-portal-wlr \
        firefox ghostty thunar spotify-launcher \
        github-cli btop fastfetch
    aur_install visual-studio-code-bin
}

setup_mirrors() {
    # https://wiki.archlinux.org/title/Reflector#systemd_service
    # weekly mirror refresh via systemd timer
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm reflector
    mkdir -p "${MOUNT}/etc/xdg/reflector"
    cat > "${MOUNT}/etc/xdg/reflector/reflector.conf" <<'EOF'
--country US
--protocol https
--age 24
--latest 50
--fastest 10
--save /etc/pacman.d/mirrorlist
EOF
    arch-chroot "$MOUNT" systemctl enable reflector.timer
}

setup_zram() {
    # https://wiki.archlinux.org/title/Zram#Using_zram-generator
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm zram-generator
    mkdir -p "${MOUNT}/etc/systemd"
    cat > "${MOUNT}/etc/systemd/zram-generator.conf" <<'EOF'
[zram0]
zram-size = ram / 2
compression-algorithm = zstd
EOF
}

setup_audio() {
    # https://wiki.archlinux.org/title/PipeWire#Installation
    # pipewire-pulse replaces pulseaudio, pipewire-alsa provides alsa compatibility
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm \
        pipewire pipewire-audio pipewire-pulse pipewire-alsa wireplumber
    # https://wiki.archlinux.org/title/Chroot#Usage
    # --global enables for all users via /etc/systemd/user/ (no D-Bus needed in chroot)
    arch-chroot "$MOUNT" systemctl --global enable \
        pipewire.socket pipewire-pulse.socket wireplumber.service
}

setup_bluetooth() {
    # https://wiki.archlinux.org/title/Bluetooth#Installation
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm bluez bluez-utils
    arch-chroot "$MOUNT" systemctl enable bluetooth.service
}

setup_power() {
    # https://wiki.archlinux.org/title/Framework_Laptop_13_(AMD_Ryzen_7040_Series)#Power_management
    # https://wiki.archlinux.org/title/Power_profiles_daemon
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm power-profiles-daemon
    arch-chroot "$MOUNT" systemctl enable power-profiles-daemon
}

setup_dropbox() {
    # https://wiki.archlinux.org/title/Dropbox#Required/optional_packages
    # python-gpgme: mandatory binary signature verification
    # libappindicator-gtk3: tray icon in waybar (sync status indicator)
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm --asdeps \
        python-gpgme libappindicator-gtk3
    aur_install dropbox

    # https://wiki.archlinux.org/title/Dropbox#Prevent_automatic_updates
    # dropbox self-updates to ~/.dropbox-dist, conflicting with the AUR package
    # read-only directory blocks self-updates, prevents systemd restart loops
    arch-chroot "$MOUNT" install -dm0 -o tk -g tk /home/tk/.dropbox-dist

    # https://wiki.archlinux.org/title/Dropbox#Filesystem_monitoring_problem
    # default 8192 is too low, dropbox registers an inotify watch per file
    mkdir -p "${MOUNT}/etc/sysctl.d"
    cat > "${MOUNT}/etc/sysctl.d/50-dropbox.conf" <<'EOF'
fs.inotify.max_user_watches = 100000
EOF

    arch-chroot "$MOUNT" systemctl --global enable dropbox.service
}

deploy_dotfiles() {
    # copy bootstrap into chroot, run as tk, then clean up
    cp "${SCRIPT_DIR}/../../.bin/bootstrap" "${MOUNT}/home/tk/bootstrap"
    arch-chroot "$MOUNT" su - tk -c '/home/tk/bootstrap --all --force'
    rm -f "${MOUNT}/home/tk/bootstrap"
}

setup_snapshots() {
    arch-chroot "$MOUNT" pacman -S --needed --noconfirm snapper snap-pac

    # https://wiki.archlinux.org/title/Snapper#Configuration_of_snapper_and_mount_point
    # snapper create-config creates a .snapshots child subvolume inside @
    # replace with our top-level @snapshots (survives rollback, already in fstab)
    umount "${MOUNT}/.snapshots"
    rmdir "${MOUNT}/.snapshots"
    arch-chroot "$MOUNT" snapper --no-dbus -c root create-config /
    btrfs subvolume delete "${MOUNT}/.snapshots"
    mkdir "${MOUNT}/.snapshots"
    mount -o "${BTRFS_OPTS},subvol=@snapshots" "$CRYPT_DEV" "${MOUNT}/.snapshots"
    chmod 750 "${MOUNT}/.snapshots"

    # https://wiki.archlinux.org/title/Snapper#Set_snapshot_limits
    # no timeline snapshots, snap-pac handles automation via pacman hooks
    # keep 10 most recent pre/post pairs, allow tk to list/diff without sudo
    sed -i \
        -e 's/^TIMELINE_CREATE=.*/TIMELINE_CREATE="no"/' \
        -e 's/^NUMBER_LIMIT=.*/NUMBER_LIMIT="10"/' \
        -e 's/^ALLOW_USERS=.*/ALLOW_USERS="tk"/' \
        "${MOUNT}/etc/snapper/configs/root"

    # https://wiki.archlinux.org/title/Locate#Btrfs
    # prevent updatedb from indexing snapshot contents
    if [[ -f "${MOUNT}/etc/updatedb.conf" ]]; then
        sed -i '/^PRUNENAMES/s/"$/ .snapshots"/' "${MOUNT}/etc/updatedb.conf"
    fi

    # deletes old snapshots daily
    arch-chroot "$MOUNT" systemctl enable snapper-cleanup.timer
}

cleanup() {
    umount -R "$MOUNT"
    unset PASSWORD
}

main() {
    precheck
    msg "tk's suzuki install"
    warn "WARNING: this will wipe ${DRIVE}"
    get_password

    msg "Updating mirrors"
    update_mirrors

    # disk
    msg "Formatting NVMe"
    format_nvme
    msg "Partitioning"
    partition
    msg "Encrypting root"
    encrypt
    msg "Creating filesystems"
    create_filesystems
    msg "Mounting filesystems"
    mount_filesystems

    # base system
    msg "Installing base system"
    install_base
    msg "Generating fstab"
    generate_fstab
    msg "Configuring system"
    configure_system
    msg "Configuring boot"
    configure_boot
    msg "Configuring network"
    configure_network

    # packages
    msg "Building paru"
    build_paru
    msg "Installing desktop packages"
    install_desktop

    # features
    msg "Setting up mirrors"
    setup_mirrors
    msg "Setting up zram"
    setup_zram
    msg "Setting up audio"
    setup_audio
    msg "Setting up Bluetooth"
    setup_bluetooth
    msg "Setting up power"
    setup_power
    msg "Setting up snapshots"
    setup_snapshots
    msg "Setting up Dropbox"
    setup_dropbox

    # user environment
    msg "Deploying dotfiles"
    deploy_dotfiles

    cleanup
    msg "Rebooting"
    reboot
}

main "$@"
