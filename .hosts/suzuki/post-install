#!/usr/bin/env bash
set -euo pipefail

# suzuki post-install
#
# After first boot, log in as user tk. Then run:
#   nmcli device wifi connect "YourNetworkName" --ask
#   ~/.hosts/suzuki/post-install

ROOT_PART="/dev/nvme0n1p2"

msg() {
    printf '\033[1;35m%s\033[0m\n' "$1"
}

precheck() {
    if (( EUID == 0 )); then
        echo "error: run as user tk, not root" >&2
        exit 1
    fi
    if ! ping -c 1 -W 3 archlinux.org &>/dev/null; then
        echo "error: no internet, connect with: nmcli device wifi connect \"YourNetworkName\" --ask" >&2
        exit 1
    fi
}

update_firmware() {
    # https://wiki.archlinux.org/title/Fwupd#Usage
    # udisks2: ESP detection, efibootmgr: UEFI firmware entries
    sudo pacman -S --needed --noconfirm fwupd udisks2 efibootmgr

    sudo fwupdmgr refresh || true

    # apply available updates, then reboot so the next run continues past this step
    # BIOS updates are staged for next reboot, do not power off while flashing
    if sudo fwupdmgr get-updates &>/dev/null; then
        sudo fwupdmgr update
        echo
        echo "Firmware updated. Reboot and re-run this script."
        exit 0
    fi
}

enroll_tpm() {
    # https://wiki.archlinux.org/title/Systemd-cryptenroll#Trusted_Platform_Module
    # binds to PCR 7 (Secure Boot state), BIOS/firmware updates may invalidate
    # re-enroll: systemd-cryptenroll --wipe-slot=tpm2 --tpm2-device=auto /dev/nvme0n1p2
    if sudo cryptsetup luksDump "$ROOT_PART" | grep -q systemd-tpm2; then
        echo "TPM already enrolled, skipping"
        return
    fi

    sudo systemd-cryptenroll --tpm2-device=auto "$ROOT_PART"
}

setup_github_ssh() {
    # openssh: ssh-keygen, github-cli: gh auth + ssh-key upload
    sudo pacman -S --needed --noconfirm openssh github-cli

    local key="$HOME/.ssh/id_ed25519"

    if [[ ! -f "$key" ]]; then
        mkdir -p ~/.ssh
        chmod 700 ~/.ssh
        ssh-keygen -t ed25519 -f "$key" -N "" -C "tk@suzuki" -q
    fi

    # device code flow, prints URL + code, user authorizes on any browser (phone works)
    if ! gh auth status &>/dev/null; then
        gh auth login --web --git-protocol ssh --skip-ssh-key -s admin:public_key
    fi

    # upload public key (gh deduplicates by key content)
    gh ssh-key add "${key}.pub" --title "suzuki" --type authentication
}

link_dropbox() {
    # https://wiki.archlinux.org/title/Dropbox#Autostart_on_boot_with_systemd
    command -v dropbox &>/dev/null || return 0

    if [[ -f "$HOME/.dropbox/info.json" ]]; then
        echo "Dropbox already linked, skipping"
        return
    fi

    # dropbox.service prints a linking URL to the journal on first login
    local url
    url=$(journalctl --user -u dropbox.service -o cat | grep -o 'https://[^ ]*' | tail -1)

    if [[ -z "$url" ]]; then
        echo "error: no Dropbox link URL found in journal" >&2
        return 1
    fi

    echo "Link your Dropbox account:"
    echo "$url"
}

create_first_snapshot() {
    # https://wiki.archlinux.org/title/Snapper#Creating_a_new_snapshot
    # delete snapshots accumulated by snap-pac during install
    sudo snapper -c root delete 1-1000 2>/dev/null || true

    # initial snapshot for the fully installed system
    sudo snapper -c root create \
        --description "suzuki post-install" --userdata "important=yes"
}

main() {
    precheck

    msg "Updating firmware"
    update_firmware

    msg "Enrolling TPM"
    enroll_tpm

    msg "Setting up GitHub SSH"
    setup_github_ssh

    msg "Linking Dropbox"
    link_dropbox

    msg "Creating first snapshot"
    create_first_snapshot

    echo
    msg "Installation complete."
    msg "Welcome to suzuki, tk"
}

main "$@"
