{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [],
    "ask": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git commit *)",
      "Bash(git commit)",
      "Bash(sudo *)",
      "Bash(rm -rf *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "model": "opus",
  "effortLevel": "high"
}
