{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },

  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "mcp__ide__getDiagnostics",
      "Skill(claude-api)"
    ],
    "deny": [],
    "ask": [
      "Bash(git *commit*)",
      "Bash(git *push*)",
      "Bash(sudo *)",
      "Bash(rm -rf *)"
    ]
  },

  "model": "opus[1m]",
  "effortLevel": "xhigh",

  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,

  "worktree": {
    "bgIsolation": "none"
  },
  "plansDirectory": "./.claude/plans",

  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.py",
    "padding": 0,
    "refreshInterval": 1
  },
  "tui": "fullscreen",

  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
